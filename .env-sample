# MultiTrust Configuration
# Copy to .env and uncomment/modify values as needed.
# Load with MultiTrustConfig.from_env()

# Enable time-based trust decay (true/false/1/0)
# MULTITRUST_ENABLE_TIME_DECAY=false

# Half-life for trust decay in seconds (default: 86400 = 24 hours)
# MULTITRUST_DECAY_HALF_LIFE_SECONDS=86400.0

# Default base rate for vacuous opinions (0.0 to 1.0)
# MULTITRUST_DEFAULT_BASE_RATE=0.5

# Default prior weight for evidence-to-opinion conversion
# MULTITRUST_DEFAULT_PRIOR_WEIGHT=2.0

# Minimum uncertainty floor after fusion (0.0 to 1.0)
# MULTITRUST_MIN_UNCERTAINTY=0.01

# Trust threshold for is_trusted() checks (0.0 to 1.0)
# MULTITRUST_TRUST_THRESHOLD=0.5

# Enable thread-safe locking in TrustManager (true/false/1/0)
# MULTITRUST_THREAD_SAFE=false

# Maximum age in seconds before an agent is considered stale (default: 604800 = 7 days)
# MULTITRUST_MAX_STALE_AGE_SECONDS=604800.0
